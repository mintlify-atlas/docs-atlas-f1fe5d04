  "keyFeatures": [
    "User authentication and registration",
    "Create and manage diary entries with text and images",
    "Friend request system with pending/accepted status",
    "Privacy controls for entry visibility",
    "Share entries with specific friends",
    "Like system for entries",
    "Image upload and management for entries",
    "Real-time social interactions between users"
  ],
  "publicApiSurface": [
    "POST /SingIn/create - User registration",
    "POST /Login/initial - User login",
    "GET /Logout - User logout",
    "POST /Entry - Create diary entry",
    "POST /Update/Entry/{entry} - Update entry",
    "DELETE /Delete/Entry/{entry} - Delete entry",
    "GET /Friends/{type?} - List friends/requests",
    "POST /Friend/Request/{id} - Send/accept friend request",
    "DELETE /Friend/Rejected/Request/{id} - Reject friend request",
    "Entry model - body, visibility, creator_id, timestamps",
    "User model - name, email, password, relationships",
    "FriendRequests model - sender_id, recived_id, status, timestamps",
    "Like model - entry likes",
    "ImageEntry model - entry image attachments"
  ]
}
